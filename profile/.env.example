# Hermes profile: management (chiaki) — secrets template
# 配備先: ~/.hermes/profiles/management/.env （chmod 600・バックアップ時は暗号化）
# 実値は本セッションで戸田さんから受領して埋める。コミット禁止。

# モデル（Claude.ai サブスクの OAuth は不可。必ず API キー）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Slack 専用アプリ（Socket Mode）
SLACK_BOT_TOKEN=xoxb-xxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxx
SLACK_ALLOWED_USERS=U9R35H06L          # 戸田のみ（ハードゲート）
SLACK_HOME_CHANNEL=C0BCE19BN2G         # #8902-chiaki-management

# Notion（既存統合トークンを再利用。タスクDBを統合に共有済みであること）
NOTION_INTEGRATION_TOKEN=ntn_xxxxxxxx

# Honcho（クラウド honcho.dev）
HONCHO_API_KEY=hon_xxxxxxxx

